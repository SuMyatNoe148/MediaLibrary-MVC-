# Email configuration for SMTP mail sending
# Used for sending system emails from the application

MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=yourgmail@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_EMAIL=yourgmail@gmail.com
MAIL_FROM_NAME="Media Library"

# Admin Account (used for initial setup only - CHANGE THESE!)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123

# Stripe Payment Keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here